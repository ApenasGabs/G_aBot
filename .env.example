# ID do grupo de administração do bot (formato: XXXXXXXXXX@g.us)
BOT_ADMIN_GROUP_ID=

# Permite comando de reboot via admin (recomendado manter false)
BOT_ALLOW_SYSTEM_REBOOT=false

# Permite comandos que exigem sudo (apt/reboot)
BOT_ALLOW_SUDO_COMMANDS=false

# Senha sudo usada pelo comando admin sys (nunca commitar .env real)
BOT_SUDO_PASSWORD=

# AI Coupon Parser (Ollama/LLM)
# Habilita o parser de cupons com IA
COUPON_AI_ENABLED=false

# URL base da API (Ollama rodando localmente)
COUPON_AI_BASE_URL=http://localhost:11434

# Modelo a ser usado
# LEVES (CPU/RAM 8GB+): qwen2.5:1.5b (934MB), llama3.2:1b (1.3GB), gemma2:2b (1.6GB)
# MÉDIOS (RAM 16GB+): phi3:mini (3.8GB), llama3.2:3b (2GB)
# PESADOS (GPU 8GB+): llama3.2:latest (4.9GB), mistral:latest (4.1GB)
COUPON_AI_MODEL=qwen2.5:1.5b

# Timeout em milliseconds (CPU mais lento que GPU: 20-30s recomendado)
COUPON_AI_TIMEOUT=20000

# Ollama Auto-Management
# Se true, ao subir o bot ele verifica a instancia e tenta iniciar automaticamente
OLLAMA_AUTO_START=true

# Se true, quando o modelo nao existir, tenta fazer pull automatico
OLLAMA_AUTO_PULL_MODELS=true

# Ordem de fallback de modelos para texto (do mais leve para mais robusto)
OLLAMA_FALLBACK_MODELS=qwen2.5:1.5b,llama3.2:1b,gemma2:2b

# Instancia padrão usada no startup e quando comando admin não informa nome
OLLAMA_DEFAULT_INSTANCE=local

# Comandos de controle da instancia local
OLLAMA_LOCAL_START_COMMAND=(systemctl start ollama >/dev/null 2>&1 || nohup ollama serve >/tmp/ollama-serve.log 2>&1 &)
OLLAMA_LOCAL_STOP_COMMAND=(systemctl stop ollama >/dev/null 2>&1 || pkill -f 'ollama serve')
OLLAMA_LOCAL_RESTART_COMMAND=(systemctl restart ollama >/dev/null 2>&1 || (pkill -f 'ollama serve'; nohup ollama serve >/tmp/ollama-serve.log 2>&1 &))

# Opcional: definir multiplas instancias em JSON
# Exemplo:
# OLLAMA_INSTANCES_JSON={"local":{"baseUrl":"http://localhost:11434","startCommand":"systemctl start ollama","stopCommand":"systemctl stop ollama","restartCommand":"systemctl restart ollama"},"gpu2":{"baseUrl":"http://192.168.0.50:11434","startCommand":"ssh user@gpu2 'systemctl start ollama'","stopCommand":"ssh user@gpu2 'systemctl stop ollama'","restartCommand":"ssh user@gpu2 'systemctl restart ollama'"}}
OLLAMA_INSTANCES_JSON=
